{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    { "source": "/platform", "destination": "/intelligence", "permanent": true },
    { "source": "/solutions/law-firms", "destination": "/intelligence#law-firms", "permanent": true },
    { "source": "/solutions/igaming-operators", "destination": "/intelligence#igaming", "permanent": true },
    { "source": "/solutions/gaming-regulators", "destination": "/intelligence#regulators", "permanent": true },
    { "source": "/solutions/law-enforcement", "destination": "/intelligence#government", "permanent": true },
    { "source": "/solutions/crypto-insurance", "destination": "/intelligence#insurance", "permanent": true },
    { "source": "/solutions/forensic-services", "destination": "/intelligence#forensic-reports", "permanent": true },
    { "source": "/forensic-services", "destination": "/intelligence", "permanent": true },
    { "source": "/crypto-compliance", "destination": "/intelligence", "permanent": true },
    { "source": "/igaming", "destination": "/intelligence#igaming", "permanent": true },
    { "source": "/events", "destination": "/insights", "permanent": true },
    { "source": "/events/:path*", "destination": "/insights", "permanent": true }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
