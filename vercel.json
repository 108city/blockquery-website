{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    { "source": "/intelligence", "destination": "/", "permanent": false },
    { "source": "/platform", "destination": "/", "permanent": false },
    { "source": "/forensic-services", "destination": "/", "permanent": false },
    { "source": "/crypto-compliance", "destination": "/", "permanent": false },
    { "source": "/igaming", "destination": "/", "permanent": false },
    { "source": "/solutions/law-firms", "destination": "/law-firms", "permanent": true },
    { "source": "/solutions/igaming-operators", "destination": "/", "permanent": false },
    { "source": "/solutions/gaming-regulators", "destination": "/", "permanent": false },
    { "source": "/solutions/law-enforcement", "destination": "/", "permanent": false },
    { "source": "/solutions/crypto-insurance", "destination": "/", "permanent": false },
    { "source": "/solutions/forensic-services", "destination": "/", "permanent": false },
    { "source": "/events", "destination": "/insights", "permanent": true },
    { "source": "/events/:path*", "destination": "/insights", "permanent": true }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
